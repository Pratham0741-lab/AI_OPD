# ═══════════════════════════════════════════════════════════
# AI OPD System — Root Environment Variables
# ═══════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values:
#   copy .env.example .env

# ── Twilio Configuration (for phone-based health-check calls) ──
# Get these from https://console.twilio.com/
TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here

# Your Twilio phone number (E.164 format, e.g., +1234567890)
TWILIO_PHONE_NUMBER=+1234567890

# Public URL where Twilio can reach your backend webhooks.
# For local development, use ngrok:
#   1. Install ngrok: https://ngrok.com/download
#   2. Run: ngrok http 8000
#   3. Copy the HTTPS URL (e.g., https://abc123.ngrok-free.app)
TWILIO_WEBHOOK_BASE_URL=https://your-ngrok-url.ngrok-free.app
