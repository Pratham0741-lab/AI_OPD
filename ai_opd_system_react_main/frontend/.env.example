# ═══════════════════════════════════════════════════════════
# VocabOPD React Frontend — Environment Variables
# ═══════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values.
# CRA requires env vars to start with REACT_APP_

# Node.js backend API URL (Express server)
REACT_APP_API_URL=http://localhost:5000

# Python backend URL (FastAPI — Twilio + patient APIs)
REACT_APP_VA_URL=http://localhost:8000
